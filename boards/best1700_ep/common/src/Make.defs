ifeq ($(CONFIG_ARCH_LEDS),y)
#CSRCS += bes_autoleds.c
else ifeq ($(CONFIG_USERLED),y)
CSRCS += bes_userleds.c
endif

ifeq ($(CONFIG_PWM),y)
CSRCS += bes_pwm.c
endif

ifeq ($(CONFIG_BES_ACCLIS2DH),y)
CSRCS +=  bes_acclis2dh.c
endif

ifeq ($(CONFIG_BES_SPI),y)
CSRCS +=  bes_spi.c
CSRCS +=  bes_board_spi_slave.c
CSRCS +=  bes_board_spi_dbgslave.c
endif

ifeq ($(CONFIG_VIDEO),y)
CSRCS +=  bes_camera_common.c

ifeq ($(CONFIG_BES_CAMSPI),y)
CSRCS +=  bes_camspi_common.c

ifeq ($(CONFIG_BES_CAMERA_GC032A),y)
CSRCS +=  bes_camspi_gc032a.c
endif
endif

ifeq ($(CONFIG_BES_CAMCSI),y)
CSRCS +=  bes_camcsi_common.c

ifeq ($(CONFIG_BES_CAMERA_GC2145),y)
CSRCS +=  bes_camcsi_gc2145.c
endif
endif

ifeq ($(CONFIG_BES_CAMUVC),y)
CSRCS += bes_camusb_uvc.c
endif
endif

ifeq ($(CONFIG_POWER),y)
CSRCS +=  bes_power.c
endif

ifeq ($(CONFIG_BES_ADC),y)
CSRCS +=  bes_adc.c
endif

ifeq ($(CONFIG_BES_BAT_VOLTAGE),y)
CSRCS +=  bes_bat_voltage.c
endif

ifeq ($(CONFIG_RPMSG_GPIO_CLIENT),y)
CSRCS += ioe_rpmsg.c
endif

ifeq ($(CONFIG_I2C_RPMSG_CLIENT),y)
CSRCS += bes_rpmsg_i2c.c
endif

ifeq ($(CONFIG_AUDIO_RPMSG_CLIENT),y)
ifneq ($(CONFIG_ARCH_CHIP_BESHIFI4),y)
CSRCS += rpmsg_audio.c
endif
endif

ifeq ($(CONFIG_BOARDCTL),y)
#CSRCS += bes_appinit.c
endif

ifeq ($(CONFIG_BES_HAVE_RGBLED),y)
CSRCS +=  bes_rgbled.c
endif

ifeq ($(CONFIG_BES_TP_TMA525C),y)
CSRCS +=  tma525c.c bes_tp_tma525c.c
endif

ifeq ($(CONFIG_BES_TP_CHSC6540),y)
CSRCS +=  bes_tp_chsc6540.c
CSRCS += bes_rpmsg_i2c.c
endif

ifeq ($(CONFIG_BES_TP_CST3240),y)
CSRCS += bes_tp_cst3240.c tp_cst3240.c
endif

ifeq ($(CONFIG_VIDEO_FB),y)
CSRCS += bes_lcdc.c
CSRCS += bes_fb.c
CSRCS += bes_lcdc_cmds.c
CSRCS += bes_lcdc_rotate.c
endif

ifeq ($(CONFIG_BES_LCD_JT4007),y)
CSRCS += board_lcd_jt4007.c
CSRCS += bes_lcdc_jt4007.c
endif

ifeq ($(CONFIG_BES_LCD_JD9165A),y)
CSRCS += board_lcd_jd9165a.c
CSRCS += bes_lcdc_jd9165a.c
ifeq ($(CONFIG_BES_TP_IST415X),y)
CSRCS += bes_tp_ist415x.c tp_ist415x.c
endif
endif

ifeq ($(CONFIG_BES_LCD_RM69090),y)
CSRCS +=  board_lcd_rm69090.c
CSRCS += bes_lcdc_rm69090.c
endif

ifeq ($(CONFIG_BES_LCD_RM69330),y)
CSRCS +=  board_lcd_rm69330.c
CSRCS += bes_lcdc_rm69330.c
endif

ifeq ($(CONFIG_BES_LCD_A064),y)
CSRCS +=  board_lcd_a064.c
CSRCS += bes_lcdc_a064.c
ifeq ($(CONFIG_BES_TP_A064_FTS),y)
CSRCS += bes_tp_a064.c tp_a064.c
endif
endif

ifeq ($(CONFIG_BES_LCD_GD050FW323X),y)
CSRCS +=  board_lcd_gd050fw323x.c
CSRCS += bes_lcdc_gd050fw323x.c
endif

ifeq ($(CONFIG_BES_LCD_HX8394),y)
CSRCS +=  board_lcd_hx8394.c
CSRCS += bes_lcdc_hx8394.c
endif

ifeq ($(CONFIG_BES_LCD_ST7703),y)
CSRCS +=  board_lcd_st7703.c
CSRCS += bes_lcdc_st7703.c
endif

ifeq ($(CONFIG_BES_LCD_ST7701S),y)
CSRCS +=  board_lcd_st7701s.c
CSRCS +=  lcd_st7701s.c
endif

ifeq ($(CONFIG_BES_LCD_ST7796U),y)
CSRCS +=  board_lcd_st7796u.c
CSRCS +=  lcd_st7796u.c
endif

ifeq ($(CONFIG_BES_LCD_ST7785M),y)
CSRCS +=  board_lcd_st7785m.c
CSRCS +=  lcd_st7785m.c
endif

ifeq ($(CONFIG_BES_LCD_ST7797),y)
CSRCS +=  board_lcd_st7797.c
CSRCS +=  lcd_st7797.c
endif

ifeq ($(CONFIG_BES_LCD_GC9503NP),y)
CSRCS +=  board_lcd_gc9503np.c
ifeq ($(CONFIG_ARCH_BOARD_CUSTOM_PRODUCT_NAME), "dx2")
CSRCS += bes_lcdc_gc9503np_dx2.c
else
CSRCS += bes_lcdc_gc9503np.c
endif
endif

ifeq ($(CONFIG_BES_EMMC),y)
CSRCS +=  board_bes_emmc.c
endif

ifeq ($(CONFIG_BES_EMMC_DEV),y)
CSRCS +=  bes_emmcdev.c
endif

ifeq ($(CONFIG_IEEE80211_BROADCOM_BCM4301X),y)
CSRCS +=  board_wlan_bcm4301x.c
endif

ifeq ($(CONFIG_BES_NAND_FLASH),y)
CSRCS +=  board_bes_nand.c
endif

ifeq ($(CONFIG_RELAY_GPIO),y)
CSRCS += board_relays_gpio.c
endif

ifneq ($(CONFIG_GEN_DSP_BIN),y)
ifeq ($(CONFIG_BES_BOARD_START_FILE_CM),y)
CSRCS += bes_start_cm.c
endif

ifeq ($(CONFIG_BES_BOARD_START_FILE_CA),y)
CSRCS += bes_start_ca.c
endif

ifeq ($(CONFIG_BES_BOARD_START_FILE_CMCP),y)
CSRCS += bes_start_cmcp.c
endif

ifeq ($(CONFIG_BES_BOARD_START_FILE_CHIP_START),y)
endif
endif

ifeq ($(CONFIG_USBDEV),y)
CSRCS += bes_composite.c
endif

ifeq ($(CONFIG_BES_AUDIO_CLIENT), y)
CSRCS += bes_audio_client.c
endif

DEPPATH += --dep-path src
VPATH += :src
CFLAGS += $(shell $(INCDIR) "$(CC)" $(TOPDIR)$(DELIM)arch$(DELIM)$(CONFIG_ARCH)$(DELIM)src$(DELIM)board$(DELIM)src)
CFLAGS += $(shell $(INCDIR) "$(CC)" $(TOPDIR)$(DELIM)drivers$(DELIM)platform$(DELIM)sensors)
CFLAGS += $(shell $(INCDIR) "$(CC)" $(TOPDIR)$(DELIM)drivers$(DELIM)platform$(DELIM)include)
CFLAGS += $(shell $(INCDIR) "$(CC)" $(TOPDIR)$(DELIM)drivers$(DELIM)platform$(DELIM)storage)
CFLAGS += $(shell $(INCDIR) "$(CC)" $(TOPDIR)$(DELIM)..$(DELIM)vendor$(DELIM)bes$(DELIM)framework$(DELIM)services$(DELIM)platform$(DELIM)drivers$(DELIM)graphic$(DELIM)lcdc)
CFLAGS += $(shell $(INCDIR) "$(CC)" $(TOPDIR)$(DELIM)..$(DELIM)vendor$(DELIM)bes$(DELIM)framework$(DELIM)services$(DELIM)platform$(DELIM)drivers$(DELIM)graphic$(DELIM)gpu)
CFLAGS += $(shell $(INCDIR) "$(CC)" $(TOPDIR)$(DELIM)..$(DELIM)vendor$(DELIM)bes$(DELIM)framework$(DELIM)services$(DELIM)platform$(DELIM)drivers$(DELIM)graphic$(DELIM)gpu$(DELIM)drv$(DELIM)vglite$(DELIM)inc)
CFLAGS += $(shell $(INCDIR) "$(CC)" $(TOPDIR)$(DELIM)..$(DELIM)apps$(DELIM)graphics$(DELIM)lvgl$(DELIM)lvgl)
