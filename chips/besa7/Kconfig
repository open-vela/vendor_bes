    bool "I2C SCL&SDA PIN defined at DDK"
    default y

config BES_I2C_DISABLE_YIELD
       bool "Donot yield i2c transfer."
       default n

config BES_I2C_LOCK
	bool "Enable i2c transfer lock on bes chips."
	default n
	---help---
		Enable i2c transfer lock on bes chips.

config BES_I2C0
	bool "use i2c port0"
	default n
	---help---
		Enable i2c port0.

config BES_I2C1
	bool "use i2c port1"
	default n
	---help---
		Enable i2c port1.

config BES_I2C2
	bool "use i2c port2"
	default n
	---help---
		Enable i2c port2.

config BES_I2C3
	bool "use i2c port3"
	default n
	---help---
		Enable i2c port3.

config BES_I2C4
	bool "use i2c port4"
	default n
	---help---
		Enable i2c port4.

config BES_GPIOI2C
	bool "use gpio i2c port 0xff"
	default n
	---help---
		Enable gpio i2c port 0xff.

config BES_I2C_TUNE_FREQ_ON_TRANSFER
	bool "tune frequency on every transfer"
	default n
	---help---
		tune frequency on every transfer.

endmenu # I2C Port Configuration
