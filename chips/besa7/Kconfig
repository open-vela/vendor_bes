	bool "double buffer support"
	default y

config FB_PANDISPLAY
	bool "pandisplay support"
	default y

config FB_DRV_ROTATE
	bool "rotate fb"
	default n

if FB_DRV_ROTATE
choice
    prompt "chose rotate method"
    default ROTATE_DMA
    help
        chose rotate method

    config ROTATE_DMA
        bool "rotate use DMA"

    config ROTATE_CPU
        bool "rotate use CPU"
endchoice
choice
    prompt "rotate 90 or 270"
    default FB_ROTATE_270
    help
        chose rotate method

    config FB_ROTATE_90
        bool "rotate 90"

    config FB_ROTATE_270
        bool "rotate 270"
endchoice
if ROTATE_DMA
choice
    prompt "chose dma rotate method"
    default ROTATE_SRC2D if FB_STATIC_BUFFER
    help
        chose dma rotate method

    config ROTATE_SRC2D
        bool "DMA rotate use source 2d, dist address is continuous"

    config ROTATE_DST2D
        bool "DMA rotate use dist 2d, source address is continuous"
endchoice
endif

config FBDST_BUFFER_SECTION
	string "The section where rotate dst framebuffer buffer is located"
	default ".psramuhs_bss"
	depends on PSRAMUHS_ENABLE
	---help---
		The section where rotate dst framebuffer buffer is located.
endif

