if ARCH_CHIP_CUSTOM

# Chip Selection

choice
	prompt "BES Chip Selection"
	default ARCH_CHIP_BES2001A7

config ARCH_CHIP_BES2001A7
	select ARCH_CORTEXA7
	select ARM_HAVE_FPU_D32
	select ARCH_HAVE_LOWVECTORS
	select ARCH_HAVE_TICKLESS
	select ARCH_HAVE_HEAPCHECK
	select ARCH_GLOBAL_IRQDISABLE
	select ARCH_HAVE_MULTICPU
	select ARM_HAVE_NEON
	select ARMV7A_HAVE_GICv2
	select ARMV7A_HAVE_PTM
	bool "Chip is BES2001A7"
	---help---
		Cortex-A7

config ARCH_CHIP_BES2003A7
	select ARCH_CORTEXA7
	select ARCH_HAVE_FPU
	select ARCH_HAVE_LOWVECTORS
	select ARCH_HAVE_TICKLESS
	select ARCH_HAVE_HEAPCHECK
	select ARCH_GLOBAL_IRQDISABLE
	select ARCH_HAVE_MULTICPU
	select ARM_HAVE_NEON
	select ARMV7A_HAVE_GICv2
	select FB_UPDATE
	select ARCH_HAVE_RESET
	select ARMV7A_HAVE_PTM
	bool "Chip is BES2003A7"
	---help---
		Cortex-A7


endchoice # BESA7 Chip Selection

config BES_DDK_DIR
	string "Bes Device Development Kit Dir"
	default "framework/services"
	---help---
		This is a name for the BES DDK Source code Dir.

