menu "BES LCDC Configuration"

config ULPS_MODE_SUPPORT
	bool "ulps mode support"
	default y

config DSI_SLEEP
	bool "dsi phy sleep support"
	default y

config LCDC_SLEEP
	bool "lcdc sleep support"
	default y

config LCDC_TE_IRQ_ENABLE
	bool "enable TE irq"
	default y

