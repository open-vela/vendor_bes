	bool "GPIO0 interrupts"
	---help---
		Enable support for 32 interrupts from GPIO port 0 pins

config BES_PORT1INTS
	bool "GPIO1 interrupts"
	---help---
		Enable support for 8 interrupts from GPIO port 1 pins

endif
endmenu # BES GPIO Interrupt Configuration
