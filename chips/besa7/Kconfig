	bool "Support audio rpmsg client"
	default n
	depends on AUDIO
	---help---
		This option mean than audio device is only a virtual interface,
                real audio implement is in other chip

config AUDIO_BES_NUM_BUFFERS_PLAYBACK
	int "Number playerback buffer for cache"
	default 2
	range 2 128
		---help---
		Used when !CONFIG_AUDIO_DRIVER_SPECIFIC_BUFFERS


config AUDIO_BES_NUM_BUFFERS_CAPTURE
	int "Number capture buffer for cache"
	default 2
	range 2 128
		---help---
		Used when !CONFIG_AUDIO_DRIVER_SPECIFIC_BUFFERS

