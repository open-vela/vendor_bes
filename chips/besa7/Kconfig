	prompt "AI Algorithm Selection"
	default AI_BES_ALG

config AI_BES_ALG
	bool "Use bes algorithm"

config HRSC_ALG
	bool "Use hrsc algorithm"

config AISPEECH_ALG
	bool "Use aispeech algorithm"

endchoice

